{
  "runtime": "Net80",
  "documentGenerator": {
    "fromDocument": {
      "url": "https://localhost:7020/swagger/v1/swagger.json"
    }
  },
  "codeGenerators": {
    "openApiToTypeScriptClient": {
      "template": "Fetch",
      "output": "apiClient.ts",
      "generateClientClasses": true,
      "generateOptionalParameters": true
    }
  }
}
